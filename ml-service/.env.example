MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/demandforecast
PORT=5001
MODEL_PATH=./models/demand_model.joblib
ENSEMBLE_PATH=./models/ensemble_model.joblib
CONFORMAL_PATH=./models/conformal_model.joblib
CLUSTER_PATH=./models/cluster_models.joblib
PPO_SB3_PATH=./models/ppo_sb3.zip
LEAD_TIME_MODEL_PATH=./models/lead_time_model.joblib
# Comma-separated allowed origins (backend URL + frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
# Optional: Redis for feature store (falls back to MongoDB if not set)
REDIS_URL=redis://localhost:6379
# Optional: MLflow tracking server
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT=demand_forecasting
# Optional: Slack webhook for drift alerts
SLACK_WEBHOOK_URL=
# Drift thresholds
PSI_THRESHOLD=0.2
MAE_DRIFT_PCT=0.15
# Cluster count for per-product models
N_CLUSTERS=4
