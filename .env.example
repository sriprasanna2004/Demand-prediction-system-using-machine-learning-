# Root .env used by docker-compose for local development
# Copy to .env and fill in real values

# --- External APIs ---
OPENWEATHER_API_KEY=your_openweather_key_here
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# --- MongoDB (only needed if NOT using docker-compose's built-in mongo) ---
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/demandforecast

# --- CORS: set to your deployed frontend URL in production ---
# ALLOWED_ORIGINS=https://demandai.vercel.app
